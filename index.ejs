<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3xl mb-5">Create Account</h3>
        <form action="register" method="post">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-md " type="text" placeholder="name" name="name" >
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-md " type="text" placeholder="username" name="username">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-md " type="number" placeholder="Age" name="age">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-md " type="text" placeholder="E-mail" name="email">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-md " type="password" placeholder="Password" name="password">
            <input type="submit" value="Create Account" class="bg-blue-500 outline-none rounded-md px-5 py-2">
        </form>
    </div>
    
</body>
</html>
